# Environment Variables for Data Pipelines
# Copy this file to .env and fill in your API keys.
# All keys are free to obtain.

# Census Bureau API Key
# Register at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Bureau of Economic Analysis (BEA) API Key
# Register at: https://apps.bea.gov/API/signup/
BEA_API_KEY=

# Federal Reserve (FRED) API Key
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# No API key needed for:
# - USASpending.gov (api.usaspending.gov)
# - Treasury Fiscal Data (api.fiscaldata.treasury.gov)
# - Medicaid.gov (data.medicaid.gov)
